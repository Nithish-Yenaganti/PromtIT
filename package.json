{
  "name": "promptit-mcp",
  "version": "3.0.0",
  "type": "module",
  "private": false,
  "description": "PromptIT MCP server and installer for repo-aware AI coding safety preflights.",
  "license": "MIT",
  "packageManager": "bun@1.3.12",
  "bin": {
    "promptit": "./src/cli.ts"
  },
  "files": [
    "src",
    "scripts",
    "README.md",
    "PROMPTENGINEER.md",
    "config.example.toml",
    "package.json",
    "bun.lock"
  ],
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "overrides": {
    "fast-uri": "^3.1.2",
    "hono": "^4.12.23",
    "ip-address": "^10.2.0",
    "qs": "^6.15.2"
  },
  "scripts": {
    "build": "bun build ./src/server.ts --outdir ./dist --target bun --packages external",
    "start": "bun run ./src/server.ts",
    "start:dist": "bun run ./dist/server.js",
    "promptit": "bun run ./src/cli.ts",
    "config:codex": "bash scripts/render-codex-config.sh",
    "test": "bun test"
  },
  "module": "src/server.ts"
}
