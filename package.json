{
  "name": "promptit-mcp",
  "version": "3.0.0",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.6.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "scripts": {
    "build": "bun build ./src/server.ts --outdir ./dist --target bun --packages external",
